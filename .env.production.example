# Production configuration. Set all secret values only in the hosting provider's
# protected environment-variable store; do not upload this file with real values.
NODE_ENV=production
HOST=0.0.0.0
# The hosting provider must supply PORT. Do not set a fixed production port.
PORT=
TRUST_PROXY=1
CORS_ALLOWED_ORIGINS=https://smartfin365.com

# Both locations must be persistent volumes outside the deployed application release.
DATA_DIR=/var/lib/smart-fin-365/data
BACKUP_STORAGE_DIR=/var/lib/smart-fin-365/backups
FINANCE_WORKBOOK_PATH=/var/lib/smart-fin-365/data/Finance_Records_Converted.xlsx
REQUIRE_EXISTING_WORKBOOK=true

PUBLIC_APP_URL=https://smartfin365.com
PUBLIC_BASE_URL=https://smartfin365.com
API_BASE_URL=https://smartfin365.com/api
FINANCE_PUBLIC_URL=https://smartfin365.com
APP_URL=https://smartfin365.com
GOOGLE_REDIRECT_URI=https://smartfin365.com/oauth2callback

FINANCE_WEB_USER=
FINANCE_WEB_PASSWORD=
AUTH_OTP_ENABLED=false
ALLOW_RUNTIME_CREDENTIAL_STORAGE=false

SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_REQUIRED=true

GOOGLE_DRIVE_FOLDER_ID=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CONFIG_ENCRYPTION_KEY=

UPSTOX_ACCESS_TOKEN=
UPSTOX_AUTO_SYNC_MS=60000
UPSTOX_HISTORY_START_DATE=2020-04-01

SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=support@smartfin365.com
